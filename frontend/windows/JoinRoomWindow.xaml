<Window x:Class="TriviaClient.JoinRoomWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TRIVIA" Height="520" Width="420"
        Background="#0a0e1a"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="CyanButton" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#00c8d4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OutlineButton" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="#00f5ff" BorderThickness="1" CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#0d1f2d"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="300">

        <TextBlock Text="JOIN ROOM"
                   FontSize="32" FontWeight="Bold"
                   Foreground="#00f5ff"
                   HorizontalAlignment="Center"
                   FontFamily="Consolas"
                   Margin="0,0,0,4"/>

        <TextBlock Text="SELECT AN ACTIVE SESSION"
                   FontSize="10" Foreground="#4a6fa5"
                   HorizontalAlignment="Center"
                   FontFamily="Consolas"
                   Margin="0,0,0,20"/>

        <Rectangle Height="1" Fill="#00f5ff" Opacity="0.3" Margin="0,0,0,15"/>

        <ListBox Name="RoomsList" Height="220" Margin="0,0,0,15"
                 Background="Transparent" BorderThickness="0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="Transparent"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Background="#0d1f2d" BorderBrush="#00f5ff" BorderThickness="1"
                            CornerRadius="3" Padding="12,8" Margin="0,3" Width="280">
                        <TextBlock Text="{Binding}" Foreground="#00f5ff"
                                   FontFamily="Consolas" FontSize="12" TextWrapping="Wrap"/>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Button Content="JOIN SESSION" Click="JoinBtn_Click"
                Style="{StaticResource CyanButton}"
                Foreground="#0a0e1a" Background="#00f5ff"
                Margin="0,0,0,8"/>

        <Button Content="REFRESH" Click="RefreshBtn_Click"
                Style="{StaticResource OutlineButton}"
                Foreground="#00f5ff" Background="Transparent"
                Margin="0,0,0,8"/>

        <Button Content="BACK" Click="BackBtn_Click"
                Style="{StaticResource OutlineButton}"
                Foreground="#00f5ff" Background="Transparent"/>

    </StackPanel>
</Window>