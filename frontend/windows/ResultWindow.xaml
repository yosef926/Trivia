<Window x:Class="TriviaClient.ResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TRIVIA" Height="520" Width="450"
        Background="#0a0e1a" WindowStartupLocation="CenterScreen">

    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="350">

        <TextBlock Text="GAME RESULTS" FontSize="32" FontWeight="Bold"
                   Foreground="#00f5ff" HorizontalAlignment="Center"
                   FontFamily="Consolas" Margin="0,0,0,4"/>

        <TextBlock Name="WinnerText" Text="WINNER: ---"
                   FontSize="13" Foreground="#f1c40f"
                   HorizontalAlignment="Center" FontFamily="Consolas"
                   FontWeight="Bold" Margin="0,0,0,20"/>

        <Rectangle Height="1" Fill="#00f5ff" Opacity="0.3" Margin="0,0,0,15"/>

        <!-- Header row -->
        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="PLAYER" Foreground="#4a6fa5" FontFamily="Consolas" FontSize="11"/>
            <TextBlock Grid.Column="1" Text="CORRECT ANSWERS" Foreground="#4a6fa5" FontFamily="Consolas" FontSize="11" HorizontalAlignment="Center"/>
            <TextBlock Grid.Column="2" Text="AVG TIME" Foreground="#4a6fa5" FontFamily="Consolas" FontSize="11" HorizontalAlignment="Right"/>
        </Grid>

        <Rectangle Height="1" Fill="#00f5ff" Opacity="0.15" Margin="0,0,0,10"/>

        <!-- Results list -->
        <ItemsControl Name="ResultsList">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Background="#0d1526" BorderBrush="#00f5ff" BorderThickness="1"
                            CornerRadius="3" Padding="10,8" Margin="0,4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding Username}"
                                       Foreground="#00f5ff" FontFamily="Consolas" FontSize="13"/>
                            <TextBlock Grid.Column="1" Text="{Binding CorrectCount}"
                                       Foreground="#00f5ff" FontFamily="Consolas" FontSize="13"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="{Binding AvgTime}"
                                       Foreground="#00f5ff" FontFamily="Consolas" FontSize="13"
                                       HorizontalAlignment="Right"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Rectangle Height="1" Fill="#00f5ff" Opacity="0.2" Margin="0,20,0,10"/>

        <Button Content="BACK TO MENU" Click="BackBtn_Click" Height="42"
                FontFamily="Consolas" FontSize="13" FontWeight="Bold" Cursor="Hand"
                Foreground="#0a0e1a" Background="#00f5ff" BorderThickness="0">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="2">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#00c8d4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>

    </StackPanel>
</Window>