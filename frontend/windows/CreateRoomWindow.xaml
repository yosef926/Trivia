<Window x:Class="TriviaClient.CreateRoomWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TRIVIA" Height="520" Width="420"
        Background="#0a0e1a"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="CyanButton" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#00c8d4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OutlineButton" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="#00f5ff" BorderThickness="1" CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#0d1f2d"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#4a6fa5"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="InputBorder" TargetType="Border">
            <Setter Property="BorderBrush" Value="#00f5ff"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#0d1526"/>
            <Setter Property="CornerRadius" Value="2"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>
    </Window.Resources>

    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="300">

        <TextBlock Text="CREATE ROOM"
                   FontSize="32" FontWeight="Bold"
                   Foreground="#00f5ff"
                   HorizontalAlignment="Center"
                   FontFamily="Consolas"
                   Margin="0,0,0,4"/>

        <TextBlock Text="CONFIGURE YOUR SESSION"
                   FontSize="10" Foreground="#4a6fa5"
                   HorizontalAlignment="Center"
                   FontFamily="Consolas"
                   Margin="0,0,0,25"/>

        <Rectangle Height="1" Fill="#00f5ff" Opacity="0.3" Margin="0,0,0,20"/>

        <TextBlock Text="ROOM NAME" Style="{StaticResource FieldLabel}"/>
        <Border Style="{StaticResource InputBorder}">
            <TextBox Name="RoomNameBox" Background="Transparent"
                     Foreground="#00f5ff" CaretBrush="#00f5ff"
                     FontFamily="Consolas" FontSize="14"
                     BorderThickness="0" Padding="10,8"/>
        </Border>

        <TextBlock Text="MAX PLAYERS" Style="{StaticResource FieldLabel}"/>
        <Border Style="{StaticResource InputBorder}">
            <TextBox Name="MaxPlayersBox" Background="Transparent"
                     Foreground="#00f5ff" CaretBrush="#00f5ff"
                     FontFamily="Consolas" FontSize="14"
                     BorderThickness="0" Padding="10,8"/>
        </Border>

        <TextBlock Text="NUMBER OF QUESTIONS" Style="{StaticResource FieldLabel}"/>
        <Border Style="{StaticResource InputBorder}">
            <TextBox Name="NumQuestionsBox" Background="Transparent"
                     Foreground="#00f5ff" CaretBrush="#00f5ff"
                     FontFamily="Consolas" FontSize="14"
                     BorderThickness="0" Padding="10,8"/>
        </Border>

        <TextBlock Text="TIME PER QUESTION (SEC)" Style="{StaticResource FieldLabel}"/>
        <Border Style="{StaticResource InputBorder}">
            <TextBox Name="TimePerQuestionBox" Background="Transparent"
                     Foreground="#00f5ff" CaretBrush="#00f5ff"
                     FontFamily="Consolas" FontSize="14"
                     BorderThickness="0" Padding="10,8"/>
        </Border>

        <Button Content="INITIALIZE ROOM" Click="CreateBtn_Click"
                Style="{StaticResource CyanButton}"
                Foreground="#0a0e1a" Background="#00f5ff"
                Margin="0,6,0,10"/>

        <Button Content="BACK" Click="BackBtn_Click"
                Style="{StaticResource OutlineButton}"
                Foreground="#00f5ff" Background="Transparent"/>

    </StackPanel>
</Window>