<Window x:Class="TriviaClient.PersonalStatsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TRIVIA" Height="420" Width="420"
        Background="#0a0e1a" WindowStartupLocation="CenterScreen">
    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="300">
        <TextBlock Text="PERSONAL STATS" FontSize="28" FontWeight="Bold"
                   Foreground="#00f5ff" HorizontalAlignment="Center"
                   FontFamily="Consolas" Margin="0,0,0,4"/>
        <TextBlock Text="YOUR MISSION RECORD" FontSize="10" Foreground="#4a6fa5"
                   HorizontalAlignment="Center" FontFamily="Consolas" Margin="0,0,0,20"/>
        <Rectangle Height="1" Fill="#00f5ff" Opacity="0.3" Margin="0,0,0,20"/>
        <Border Background="#0d1526" BorderBrush="#00f5ff" BorderThickness="1"
                CornerRadius="3" Padding="20,15" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Name="AvgTimeText"     Foreground="#00f5ff" FontFamily="Consolas" FontSize="13" Margin="0,5"/>
                <TextBlock Name="CorrectAnsText"  Foreground="#00f5ff" FontFamily="Consolas" FontSize="13" Margin="0,5"/>
                <TextBlock Name="TotalAnsText"    Foreground="#00f5ff" FontFamily="Consolas" FontSize="13" Margin="0,5"/>
                <TextBlock Name="GamesPlayedText" Foreground="#00f5ff" FontFamily="Consolas" FontSize="13" Margin="0,5"/>
            </StackPanel>
        </Border>
        <Button Content="BACK" Click="BackBtn_Click" Height="42"
                FontFamily="Consolas" FontSize="13" Cursor="Hand"
                Foreground="#00f5ff" Background="Transparent">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="#00f5ff" BorderThickness="1" CornerRadius="2">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>
    </StackPanel>
</Window>