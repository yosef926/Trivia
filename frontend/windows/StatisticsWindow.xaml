<Window x:Class="TriviaClient.StatisticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TRIVIA" Height="420" Width="420"
        Background="#0a0e1a" WindowStartupLocation="CenterScreen">
    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="300">
        <TextBlock Text="STATISTICS" FontSize="32" FontWeight="Bold"
                   Foreground="#00f5ff" HorizontalAlignment="Center"
                   FontFamily="Consolas" Margin="0,0,0,4"/>
        <TextBlock Text="MISSION ANALYTICS" FontSize="10" Foreground="#4a6fa5"
                   HorizontalAlignment="Center" FontFamily="Consolas" Margin="0,0,0,25"/>
        <Rectangle Height="1" Fill="#00f5ff" Opacity="0.3" Margin="0,0,0,20"/>
        <Button Content="PERSONAL STATISTICS" Click="PersonalBtn_Click"
                Height="48" FontFamily="Consolas" FontSize="13" FontWeight="Bold"
                Foreground="#0a0e1a" Background="#00f5ff" Cursor="Hand"
                Margin="0,0,0,10" BorderThickness="0">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="2">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#00c8d4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>
        <Button Content="HIGH SCORES" Click="HighScoresBtn_Click"
                Height="48" FontFamily="Consolas" FontSize="13" FontWeight="Bold"
                Foreground="#0a0e1a" Background="#00f5ff" Cursor="Hand"
                Margin="0,0,0,20" BorderThickness="0">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="2">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#00c8d4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>
        <Rectangle Height="1" Fill="#00f5ff" Opacity="0.2" Margin="0,0,0,10"/>
        <Button Content="BACK" Click="BackBtn_Click" Height="42"
                FontFamily="Consolas" FontSize="13" Cursor="Hand"
                Foreground="#00f5ff" Background="Transparent" BorderThickness="0">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="#00f5ff" BorderThickness="1" CornerRadius="2">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#0d1f2d"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>
    </StackPanel>
</Window>