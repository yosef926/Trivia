<Window x:Class="TriviaClient.MenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TRIVIA" Height="450" Width="420"
        Background="#0a0e1a"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="MenuButton" TargetType="Button">
            <Setter Property="Height" Value="48"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#0a0e1a"/>
            <Setter Property="Background" Value="#00f5ff"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="0,6,0,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#00c8d4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ExitButton" TargetType="Button">
            <Setter Property="Height" Value="48"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#00f5ff"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="0,6,0,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="#00f5ff" BorderThickness="1" CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#0d1f2d"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="300">

        <TextBlock Text="TRIVIA"
                   FontSize="40" FontWeight="Bold"
                   Foreground="#00f5ff"
                   HorizontalAlignment="Center"
                   FontFamily="Consolas"
                   Margin="0,0,0,4"/>

        <TextBlock Text="COMMAND CENTER"
                   FontSize="10" Foreground="#4a6fa5"
                   HorizontalAlignment="Center"
                   FontFamily="Consolas"
                   Margin="0,0,0,25"/>

        <Rectangle Height="1" Fill="#00f5ff" Opacity="0.3" Margin="0,0,0,20"/>

        <Button Content="CREATE ROOM"  Click="CreateRoomBtn_Click" Style="{StaticResource MenuButton}"/>
        <Button Content="JOIN ROOM"    Click="JoinRoomBtn_Click"   Style="{StaticResource MenuButton}"/>
        <Button Content="STATISTICS"   Click="StatisticsBtn_Click" Style="{StaticResource MenuButton}"/>

        <Rectangle Height="1" Fill="#00f5ff" Opacity="0.2" Margin="0,20,0,0"/>

        <Button Content="EXIT" Click="ExitBtn_Click" Style="{StaticResource ExitButton}"/>

    </StackPanel>
</Window>