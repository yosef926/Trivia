<Window x:Class="TriviaClient.RoomWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TRIVIA" Height="520" Width="420"
        Background="#0a0e1a" WindowStartupLocation="CenterScreen">
    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="300">
        <TextBlock Text="ROOM" FontSize="32" FontWeight="Bold"
                   Foreground="#00f5ff" HorizontalAlignment="Center"
                   FontFamily="Consolas" Margin="0,0,0,4"/>
        <TextBlock Name="AdminText" FontSize="10" Foreground="#4a6fa5"
                   HorizontalAlignment="Center" FontFamily="Consolas" Margin="0,0,0,20"/>
        <Rectangle Height="1" Fill="#00f5ff" Opacity="0.3" Margin="0,0,0,15"/>
        <TextBlock Text="CONNECTED AGENTS" Foreground="#4a6fa5"
                   FontFamily="Consolas" FontSize="11" Margin="0,0,0,8"/>
        <ListBox Name="PlayersList" Height="160" Margin="0,0,0,15"
                 Background="Transparent" BorderThickness="0">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Background="#0d1526" BorderBrush="#00f5ff" BorderThickness="1"
                            CornerRadius="2" Padding="10,6" Margin="0,2" Width="260">
                        <TextBlock Text="{Binding}" Foreground="#00f5ff"
                                   FontFamily="Consolas" FontSize="13"/>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <Button Name="StartBtn" Content="START GAME" Click="StartBtn_Click"
                Height="42" FontFamily="Consolas" FontSize="13" FontWeight="Bold"
                Foreground="#0a0e1a" Background="#2ecc71" Cursor="Hand"
                Margin="0,0,0,8" BorderThickness="0">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="2">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>
        <Button Name="CloseBtn" Content="CLOSE ROOM" Click="CloseBtn_Click"
                Height="42" FontFamily="Consolas" FontSize="13" FontWeight="Bold"
                Foreground="#0a0e1a" Background="#e74c3c" Cursor="Hand"
                Margin="0,0,0,8" BorderThickness="0">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="2">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>
        <Button Name="BackBtn" Content="BACK" Click="BackBtn_Click" Height="42"
                FontFamily="Consolas" FontSize="13" Cursor="Hand"
                Foreground="#00f5ff" Background="Transparent" BorderThickness="0">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="#00f5ff" BorderThickness="1" CornerRadius="2">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>
    </StackPanel>
</Window>