<Window x:Class="TriviaClient.SignupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TRIVIA" Height="520" Width="420"
        Background="#0a0e1a" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#4a6fa5"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style x:Key="InputBorder" TargetType="Border">
            <Setter Property="BorderBrush" Value="#00f5ff"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#0d1526"/>
            <Setter Property="CornerRadius" Value="2"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>
    </Window.Resources>
    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="300">
        <TextBlock Text="REGISTER" FontSize="36" FontWeight="Bold"
                   Foreground="#00f5ff" HorizontalAlignment="Center"
                   FontFamily="Consolas" Margin="0,0,0,4"/>
        <TextBlock Text="CREATE YOUR ARCHIVE" FontSize="10" Foreground="#4a6fa5"
                   HorizontalAlignment="Center" FontFamily="Consolas" Margin="0,0,0,25"/>
        <Rectangle Height="1" Fill="#00f5ff" Opacity="0.3" Margin="0,0,0,20"/>
        <TextBlock Text="USERNAME" Style="{StaticResource FieldLabel}"/>
        <Border Style="{StaticResource InputBorder}">
            <TextBox Name="UsernameBox" Background="Transparent" Foreground="#00f5ff"
                     CaretBrush="#00f5ff" FontFamily="Consolas" FontSize="14"
                     BorderThickness="0" Padding="10,8"/>
        </Border>
        <TextBlock Text="PASSWORD" Style="{StaticResource FieldLabel}"/>
        <Border Style="{StaticResource InputBorder}">
            <PasswordBox Name="PasswordBox" Background="Transparent" Foreground="#00f5ff"
                         CaretBrush="#00f5ff" FontFamily="Consolas" FontSize="14"
                         BorderThickness="0" Padding="10,8"/>
        </Border>
        <TextBlock Text="EMAIL" Style="{StaticResource FieldLabel}"/>
        <Border Style="{StaticResource InputBorder}">
            <TextBox Name="EmailBox" Background="Transparent" Foreground="#00f5ff"
                     CaretBrush="#00f5ff" FontFamily="Consolas" FontSize="14"
                     BorderThickness="0" Padding="10,8"/>
        </Border>
        <Button Content="CREATE ARCHIVE" Click="SignupBtn_Click" Height="42"
                FontFamily="Consolas" FontSize="13" FontWeight="Bold"
                Foreground="#0a0e1a" Background="#00f5ff" Cursor="Hand"
                Margin="0,6,0,10" BorderThickness="0">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="2">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#00c8d4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>
        <Button Content="BACK TO LOGIN" Click="BackBtn_Click" Height="42"
                FontFamily="Consolas" FontSize="13" Cursor="Hand"
                Foreground="#00f5ff" Background="Transparent" BorderThickness="0">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="#00f5ff" BorderThickness="1" CornerRadius="2">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#0d1f2d"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>
    </StackPanel>
</Window>